{
  "name": "@hrsk/lettergen-ui-kit",
  "private": false,
  "version": "0.1.1",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "dist/style.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "rename-icons": "node scripts/rename-icons.cjs",
    "generate-icons": "pnpm run rename-icons && pnpm dlx @svgr/cli --icon --out-dir src/icons/components --jsx-runtime automatic --typescript --ref --memo --replace-attr-values \"#000=currentcolor\"  --replace-attr-values \"#fff=currentcolor\" -- src/assets/icons/svg && node scripts/replace-color.cjs"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "clsx": "^2.1.1",
    "overlayscrollbars": "^2.14.0",
    "overlayscrollbars-react": "^0.5.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.1",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.17",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "react-router-dom": "^7.13.1",
    "sass": "^1.98.0",
    "storybook": "^10.2.17",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
